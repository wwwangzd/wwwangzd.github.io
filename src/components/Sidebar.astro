---
interface Props {
  profile: typeof import("../content/profile").profile;
}

const { profile } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\/+/, "")}`;
const resolveHref = (href: string) =>
  href.startsWith("/") ? withBase(href) : href;
const emailLink = profile.links.find((link) => link.type === "email");
const inlineLinks = profile.links.filter((link) => link.type !== "email");
---

<aside class="profile-sidebar" aria-label="个人信息">
  <img
    class="avatar"
    src={withBase(profile.avatar)}
    alt={`${profile.name} 的照片`}
  />
  <h1>{profile.name}</h1>
  <p class="nickname">{profile.nickname}</p>
  <p class="bio">{profile.bio}</p>

  <ul aria-label="外部链接">
    {emailLink && (
      <li>
        <a href={resolveHref(emailLink.href)}>{emailLink.label}</a>
      </li>
    )}
    <li>
      {inlineLinks.map((link, index) => (
        <>
          {index > 0 && <span class="link-separator">·</span>}
          <a href={resolveHref(link.href)} target="_blank" rel="noreferrer">
            {link.label}
          </a>
        </>
      ))}
    </li>
  </ul>

  <nav class="section-nav" aria-label="页面导航">
    <ul>
      {profile.sections.map((section) => (
        <li>
          <a href={`#${section.id}`}>{section.title}</a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
  .profile-sidebar {
    position: sticky;
    top: 0;
    align-self: start;
  }

  .avatar {
    display: block;
    width: min(100%, 220px);
    aspect-ratio: 1 / 1;
    object-fit: cover;
    margin-bottom: 20px;
  }

  h1 {
    margin: 0 0 4px;
    font-size: 1.45rem;
    line-height: 1.2;
  }

  p,
  ul {
    margin: 0 0 14px;
  }

  ul {
    padding: 0;
    list-style: none;
  }

  li {
    margin: 4px 0;
  }

  .link-separator {
    margin: 0 2px;
  }

  .section-nav a {
    color: var(--muted);
  }

  .nickname,
  .bio {
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .profile-sidebar {
      position: static;
    }

    .avatar {
      width: 160px;
    }
  }
</style>
